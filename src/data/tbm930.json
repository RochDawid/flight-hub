          "confirmation": "Three green"
        },
        {
          "id": "flaps-landing",
          "action": "Flaps - LANDING",
          "confirmation": "Landing configuration complete"
        },
        {
          "id": "stable-approach",
          "action": "Stable approach - Confirm",
          "confirmation": "On path, on speed, landing checks complete"
