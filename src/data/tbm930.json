        {
          "id": "parking-brake-set",
          "action": "Parking brake - SET",
          "confirmation": "Aircraft secure"
        },
        {
          "id": "battery-on",
          "action": "Battery - ON",
          "confirmation": "Main electrical power available"
        },
        {
          "id": "gpu-as-needed",
          "action": "GPU or generator source - Available as needed",
          "confirmation": "Stable power for setup",
          "note": "Use ground power in the sim when you want more setup time before engine start."
        },
        {
          "id": "fuel-quantity",
          "action": "Fuel quantity - Checked",
          "confirmation": "Fuel supports route and reserve"
        },
        {
          "id": "lights-prestart",
          "action": "Beacon - ON",
          "confirmation": "Start warning active"
        }
      ]
    },
    {
      "id": "engine-start",
