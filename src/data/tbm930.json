          "action": "Flare and touchdown - Execute",
          "confirmation": "Main gear down under control"
        },
        {
          "id": "reverse-beta",
          "action": "Reverse or beta range - As needed",
          "confirmation": "Aircraft decelerating"
        },
        {
          "id": "manual-braking",
          "action": "Braking - As required",
          "confirmation": "Safe taxi speed achieved"
